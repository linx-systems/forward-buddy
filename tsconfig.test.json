{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": ".test-dist"
  },
  "include": [
    "types/**/*.d.ts",
    "lib/**/*.ts",
    "background/**/*.ts",
    "popup/**/*.ts",
    "options/**/*.ts",
    "messageDisplay/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".test-dist"
  ]
}
