{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": ".test-dist"
  },
  "include": [
    "src/types/**/*.d.ts",
    "src/lib/**/*.ts",
    "src/background/**/*.ts",
    "src/popup/**/*.ts",
    "src/options/**/*.ts",
    "src/messageDisplay/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".test-dist"
  ]
}
