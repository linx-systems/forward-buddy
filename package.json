{
  "name": "forward-buddy",
  "version": "0.1.0",
  "private": true,
  "description": "Thunderbird MailExtension for managing ForwardEmail aliases",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-static.mjs",
    "build:watch": "node scripts/sync-static.mjs && tsc -p tsconfig.json --watch",
    "pretest": "tsc -p tsconfig.test.json",
    "test": "node --test .test-dist/test/*.test.js",
    "lint": "eslint 'src/lib/**/*.ts' 'src/background/**/*.ts' 'src/popup/**/*.ts' 'src/options/**/*.ts' 'src/messageDisplay/**/*.ts'",
    "lint:fix": "eslint --fix 'src/lib/**/*.ts' 'src/background/**/*.ts' 'src/popup/**/*.ts' 'src/options/**/*.ts' 'src/messageDisplay/**/*.ts'",
    "package": "bun run build && cd dist && zip -rFS ../forwardemail.xpi .",
    "package:source": "zip -rFS forwardemail-source.zip . -x '.git/*' 'node_modules/*' 'dist/*' '.test-dist/*' '.idea/*' '.claude/*' 'CLAUDE.md' '.tldr/*' '*.xpi' '.gitignore' '.tldrignore' '*.zip' 'bun.lock'"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
